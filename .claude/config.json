{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:password@localhost:5432/zklms"
      ],
      "description": "Akses direkt ne PostgreSQL DB — per query, debug, inspektim skeme"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "description": "Akses i zgjeruar ne filesystem te projektit"
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "REPLACE_WITH_YOUR_GITHUB_TOKEN"
      },
      "description": "Menaxhim repo, commits, branches, PRs"
    }
  }
}
