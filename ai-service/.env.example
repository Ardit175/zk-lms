AZURE_OPENAI_ENDPOINT="https://zk-lms.openai.azure.com/"
AZURE_OPENAI_API_KEY="your-azure-openai-key"
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
AZURE_OPENAI_DEPLOYMENT_GPT="gpt-4o"
AZURE_OPENAI_DEPLOYMENT_WHISPER="whisper"

BACKEND_URL="http://localhost:4000"
PORT=8000

# Optional shared secret the backend must send as X-Internal-Token. Must match
# AI_SERVICE_TOKEN in the backend. Leave empty to disable the check (local dev).
AI_SERVICE_TOKEN=""
